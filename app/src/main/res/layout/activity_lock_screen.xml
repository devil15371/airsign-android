<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/lockScreenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B11"
    android:padding="24dp">

    <!-- Lock Status Title -->
    <TextView
        android:id="@+id/tvLockTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒 DEVICE SECURED"
        android:textColor="#ff3366"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lock description -->
    <TextView
        android:id="@+id/tvLockDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Authenticate identity via AirSign gesture"
        android:textColor="#94a3b8"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvLockTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Drawing Pad container -->
    <FrameLayout
        android:id="@+id/frameCanvasLock"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="40dp"
        android:background="#151e30"
        app:layout_constraintTop_toBottomOf="@id/tvLockDesc"
        app:layout_constraintBottom_toTopOf="@id/tvStatusReport"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.airsign.signal.DrawingCanvas
            android:id="@+id/drawingCanvasLock"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tvLockInstructions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Draw Gesture"
            android:textColor="#64748b"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Status report / Verification matches text -->
    <TextView
        android:id="@+id/tvStatusReport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready for Verification"
        android:textColor="#00f0ff"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
